# === Google Gemini ===
# Get yours at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === Finnhub (stocks primary) ===
# Get yours at https://finnhub.io/dashboard
FINNHUB_API_KEY=your_finnhub_api_key_here

# === Alpha Vantage (stocks fallback) ===
# Get yours at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# === App config ===
NODE_ENV=development
# Structured JSON logging: debug | info | warn | error
LOG_LEVEL=info

# Optional developer chat route. Keep disabled for the public demo unless you
# intentionally want /api/chat to spend Gemini quota in production.
ENABLE_PUBLIC_CHAT=false
